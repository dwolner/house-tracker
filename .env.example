# No API keys required — walk score is fetched directly from Redfin

# ── Email notifications ──────────────────────────────────────────────────────
# SMTP credentials (Gmail: use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Where to send alerts (comma-separated for multiple recipients)
NOTIFY_TO=you@gmail.com

# Minimum score to trigger an email for new listings (default: 70)
NOTIFY_SCORE_THRESHOLD=70

# ── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression for automatic polling (default: 7am daily)
# Format: minute hour day-of-month month day-of-week
POLL_SCHEDULE=0 7 * * *
